#!/usr/bin/env python3
"""Durably archive mbsync's Gmail All Mail copies before optional UID MOVE.

The default ``sync`` is deliberately non-destructive.  Gmail changes require
the explicit ``--move-gmail`` switch and are made only after remote backup
verification.  Message bodies and OAuth tokens are never logged.
"""

import argparse
import contextlib
import email.parser
import fcntl
import hashlib
import imaplib
import json
import os
from pathlib import Path
import re
import shlex
import socket
import sqlite3
import stat
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone

ROOT = Path(os.environ.get("GMAIL_ARCHIVE_ROOT", "/data/mail/gmail"))
ARCHIVE = ROOT / "archive"
DB = Path(os.environ.get("GMAIL_ARCHIVE_DB", str(ROOT / ".gmail-archive.sqlite3")))
LOCK = Path(os.environ.get("GMAIL_ARCHIVE_LOCK", str(Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "gmail-archive.lock")))
REMOTE = "argonaut"
REMOTE_MAIL = "/tier3/backup/pj-arm64-ampere/gmail/"
REMOTE_ARCHIVE = REMOTE_MAIL + "archive/"
REMOTE_NOTMUCH = "/tier3/backup/pj-arm64-ampere/notmuch/"

SCHEMA = """
CREATE TABLE IF NOT EXISTS messages (
 id INTEGER PRIMARY KEY, requested_at TEXT NOT NULL, source_rel TEXT NOT NULL UNIQUE,
 archive_rel TEXT NOT NULL UNIQUE, near_uid INTEGER NOT NULL, far_uid INTEGER NOT NULL,
 source_uidvalidity INTEGER NOT NULL, message_id TEXT, x_gm_msgid TEXT, size INTEGER NOT NULL,
 sha256 TEXT NOT NULL, backup_verified_at TEXT, state TEXT NOT NULL, attempts INTEGER NOT NULL DEFAULT 0,
 last_error TEXT, UNIQUE(source_uidvalidity, far_uid));
CREATE TABLE IF NOT EXISTS deletion_intents (
 message_ref TEXT PRIMARY KEY, refreshed_at TEXT NOT NULL);
CREATE TABLE IF NOT EXISTS purge_requests (
 message_id INTEGER PRIMARY KEY REFERENCES messages(id), requested_at TEXT NOT NULL,
 eligible_at TEXT NOT NULL, state TEXT NOT NULL, remote_deleted_at TEXT,
 local_deleted_at TEXT, attempts INTEGER NOT NULL DEFAULT 0, last_error TEXT);
"""

PURGE_GRACE_DAYS = 30
PURGE_MAX_MESSAGES = 100
PURGE_MAX_BYTES = 1024 * 1024 * 1024

def now():
    return datetime.now(timezone.utc).isoformat(timespec="seconds")

def run(argv, *, input_data=None, capture=False, cwd=None):
    """Run an argv-only subprocess, raising a concise error on failure."""
    return subprocess.run(argv, input=input_data, check=True, cwd=cwd,
                          stdout=subprocess.PIPE if capture else None,
                          stderr=subprocess.PIPE if capture else None)

@contextlib.contextmanager
def timed(label):
    """Report wall-clock phase duration without exposing message data."""
    started = time.monotonic()
    try:
        yield
    finally:
        elapsed = time.monotonic() - started
        print(f"gmail-archive: timing {label}: {elapsed:.3f}s", file=sys.stderr)

def connect(readonly=False):
    con = sqlite3.connect(f"file:{DB}?mode=ro" if readonly else DB,
                          uri=readonly, timeout=30)
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA foreign_keys=ON")
    if not readonly:
        con.execute("PRAGMA journal_mode=WAL")
        con.execute("PRAGMA synchronous=FULL")
        con.executescript(SCHEMA)
    return con

@contextlib.contextmanager
def locked():
    LOCK.parent.mkdir(parents=True, exist_ok=True)
    with LOCK.open("a") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        yield

def sha(path):
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for block in iter(lambda: fh.read(1024 * 1024), b""):
            h.update(block)
    return h.hexdigest()

def fsync_dir(path):
    fd = os.open(path, os.O_RDONLY | os.O_DIRECTORY)
    try: os.fsync(fd)
    finally: os.close(fd)

def cmd_init(_args):
    for part in ("cur", "new", "tmp"):
        (ARCHIVE / part).mkdir(parents=True, exist_ok=True)
    DB.parent.mkdir(parents=True, exist_ok=True)
    with connect() as con: con.executescript(SCHEMA)
    run(["notmuch", "config", "set", "search.exclude_tags", "deleted"])
    print(f"initialized {DB}")

def state_file():
    path = ROOT / "[Gmail]" / "All Mail" / ".mbsyncstate"
    st = path.lstat()
    if not stat.S_ISREG(st.st_mode):
        raise RuntimeError(f"mbsync state is not a regular file: {path}")
    return path

def parse_state(path):
    """Return UIDVALIDITY and near->far UID mapping from an mbsync state file."""
    validity = None
    mapping = {}
    for line in path.read_text(errors="strict").splitlines():
        m = re.match(r"(?:Far)?UidValidity\s+(\d+)$", line, re.I)
        if m: validity = int(m.group(1))
        m = re.fullmatch(r"(\d+)\s+(\d+)(?:\s+(\S*))?", line)
        if m:
            far, near = int(m.group(1)), int(m.group(2))
            if near in mapping and mapping[near] != far:
                raise RuntimeError(f"conflicting far UIDs for near UID {near}")
            mapping[near] = far
    if validity is None:
        raise RuntimeError("source UIDVALIDITY absent from .mbsyncstate")
    return validity, mapping

def headers(path):
    with path.open("rb") as fh:
        msg = email.parser.BytesParser().parse(fh, headersonly=True)
    return msg.get("Message-ID")

def project_tag(message_id, add=(), remove=()):
    if not message_id or "\n" in message_id:
        return
    terms = [*("+" + x for x in add), *("-" + x for x in remove)]
    run(["notmuch", "tag", *terms, "--", f"id:{message_id}"])

def project_best_effort(message_id, add=(), remove=()):
    try:
        project_tag(message_id, add, remove)
    except (OSError, subprocess.CalledProcessError) as exc:
        print(f"gmail-archive: warning: notmuch projection failed: {exc}", file=sys.stderr)

def refresh_deletions(con):
    out = run(["notmuch", "search", "--output=messages", "tag:deleted"], capture=True).stdout
    stamp = now()
    con.execute("DELETE FROM deletion_intents")
    con.executemany("INSERT INTO deletion_intents VALUES (?,?)",
                    ((x.decode("utf-8", "surrogateescape"), stamp) for x in out.splitlines()))

    return current_deletion_paths()

def current_deletion_paths():
    """Return the current physical files for messages tagged deleted."""
    out = run(["notmuch", "search", "--format=text0", "--output=files", "tag:deleted"],
              capture=True).stdout
    return {Path(os.fsdecode(path)) for path in out.split(b"\0") if path}

def reconcile_purge_requests(con, deletion_paths):
    """Create or cancel reversible purge requests from current Notmuch tags."""
    deleted_rels = set()
    for path in deletion_paths:
        try:
            deleted_rels.add(path.relative_to(ARCHIVE).as_posix())
        except ValueError:
            continue
    stamp = now()
    eligible = (datetime.now(timezone.utc) + timedelta(days=PURGE_GRACE_DAYS)).isoformat(
        timespec="seconds")
    rows = con.execute(
        "SELECT m.id,m.archive_rel,m.message_id,p.state FROM messages m "
        "LEFT JOIN purge_requests p ON p.message_id=m.id WHERE m.state='FINALIZED'").fetchall()
    for row in rows:
        if row["archive_rel"] in deleted_rels:
            if row["state"] is None:
                con.execute(
                    "INSERT INTO purge_requests(message_id,requested_at,eligible_at,state) "
                    "VALUES(?,?,?,'WAITING')", (row["id"], stamp, eligible))
                project_best_effort(row["message_id"], add=("purge-pending",))
            elif row["state"] == "CANCELED":
                con.execute(
                    "UPDATE purge_requests SET requested_at=?,eligible_at=?,state='WAITING',"
                    "remote_deleted_at=NULL,local_deleted_at=NULL,attempts=0,last_error=NULL "
                    "WHERE message_id=?", (stamp, eligible, row["id"]))
                project_best_effort(row["message_id"], add=("purge-pending",),
                                    remove=("purge-error",))
        elif row["state"] == "WAITING":
            con.execute("UPDATE purge_requests SET state='CANCELED',last_error=NULL WHERE message_id=?",
                        (row["id"],))
            project_best_effort(row["message_id"],
                                remove=("purge-pending", "purge-error"))
    con.commit()

def archive_batch(con, limit, deletion_paths):
    uidvalidity, mapping = parse_state(state_file())
    files = []
    for box in ("cur", "new"):
        for p in sorted((state_file().parent / box).iterdir()):
            m = re.search(r",U=(\d+)(?:,|:|$)", p.name)
            if m and stat.S_ISREG(p.lstat().st_mode) and int(m.group(1)) in mapping:
                files.append((p, int(m.group(1))))
    files.sort(key=lambda item: (item[0] not in deletion_paths, item[0]))
    done = 0
    for src, near in files:
        if done >= limit: break
        rel = src.relative_to(ROOT).as_posix()
        if con.execute("SELECT 1 FROM messages WHERE source_uidvalidity=? AND far_uid=?",
                       (uidvalidity, mapping[near])).fetchone(): continue
        dest = ARCHIVE / src.parent.name / src.name
        digest, size = sha(src), src.stat().st_size
        if dest.exists():
            ds = dest.lstat()
            if not stat.S_ISREG(ds.st_mode) or ds.st_size != size or sha(dest) != digest:
                raise RuntimeError(f"archive collision (left untouched): {dest}")
        else:
            os.link(src, dest)
            fsync_dir(dest.parent)
        con.execute("INSERT INTO messages(requested_at,source_rel,archive_rel,near_uid,far_uid,source_uidvalidity,message_id,size,sha256,state) VALUES(?,?,?,?,?,?,?,?,?,?)",
                    (now(), rel, dest.relative_to(ARCHIVE).as_posix(), near, mapping[near], uidvalidity,
                     headers(src), size, digest, "ARCHIVED"))
        con.commit()
        project_best_effort(headers(src), add=("archive-pending",))
        done += 1

VERIFY_CODE = """import sys,json,os,hashlib,stat
root=os.path.realpath(sys.argv[1])
for x in json.load(sys.stdin):
 rel=None
 try:
  rel=x['path']; p=os.path.join(root,rel)
  if not isinstance(rel,str) or os.path.isabs(rel) or '..' in rel.split('/'): raise ValueError()
  st=os.lstat(p)
  if not stat.S_ISREG(st.st_mode) or os.path.commonpath((root,os.path.realpath(p))) != root: raise ValueError()
  h=hashlib.sha256()
  with open(p,'rb') as f:
   for b in iter(lambda:f.read(1048576),b''): h.update(b)
  ok=st.st_size==x['size'] and h.hexdigest()==x['sha256']
 except Exception: ok=False
 print(json.dumps({'path':rel,'ok':ok},separators=(',',':')))
"""

REMOTE_DELETE_CODE = """import sys,json,os,hashlib,stat
root=os.path.realpath(sys.argv[1])
for x in json.load(sys.stdin):
 rel=None
 try:
  rel=x['path']; p=os.path.join(root,rel)
  if not isinstance(rel,str) or os.path.isabs(rel) or '..' in rel.split('/'): raise ValueError()
  if os.path.commonpath((root,os.path.realpath(p))) != root: raise ValueError()
  try: st=os.lstat(p)
  except FileNotFoundError:
   if not x.get('allow_missing'): raise
  else:
   if not stat.S_ISREG(st.st_mode) or st.st_nlink != 1 or st.st_size != x['size']: raise ValueError()
   h=hashlib.sha256()
   with open(p,'rb') as f:
    for b in iter(lambda:f.read(1048576),b''): h.update(b)
   if h.hexdigest()!=x['sha256']: raise ValueError()
   os.unlink(p); fd=os.open(os.path.dirname(p),os.O_RDONLY|os.O_DIRECTORY)
   try: os.fsync(fd)
   finally: os.close(fd)
  ok=not os.path.lexists(p)
 except Exception: ok=False
 print(json.dumps({'path':rel,'ok':ok},separators=(',',':')))
"""

def remote_verify(root, expected):
    command = shlex.join(["python3", "-c", VERIFY_CODE, root])
    output = run(["ssh", REMOTE, command], input_data=json.dumps(expected).encode(),
                 capture=True).stdout.splitlines()
    wanted = {x["path"] for x in expected}
    if len(wanted) != len(expected):
        raise RuntimeError("duplicate expected verification path")
    seen = set()
    for line in output:
        try: record = json.loads(line)
        except (ValueError, TypeError) as exc: raise RuntimeError("malformed remote verification response") from exc
        if (not isinstance(record, dict) or set(record) != {"path", "ok"} or
                record["path"] not in wanted or record["path"] in seen or record["ok"] is not True):
            raise RuntimeError("invalid remote verification response")
        seen.add(record["path"])
    if seen != wanted:
        raise RuntimeError("incomplete remote verification response")

def remote_delete(root, expected):
    """Delete exact verified remote files and require structured acknowledgement."""
    command = shlex.join(["python3", "-c", REMOTE_DELETE_CODE, root])
    output = run(["ssh", REMOTE, command], input_data=json.dumps(expected).encode(),
                 capture=True).stdout.splitlines()
    wanted = {x["path"] for x in expected}
    seen = set()
    for line in output:
        try: record = json.loads(line)
        except (ValueError, TypeError) as exc:
            raise RuntimeError("malformed remote deletion response") from exc
        if (not isinstance(record, dict) or set(record) != {"path", "ok"} or
                record["path"] not in wanted or record["path"] in seen or
                record["ok"] is not True):
            raise RuntimeError("invalid remote deletion response")
        seen.add(record["path"])
    if seen != wanted:
        raise RuntimeError("incomplete remote deletion response")

def backup_rows(con):
    rows = con.execute("SELECT * FROM messages WHERE state IN ('ARCHIVED','ERROR') AND backup_verified_at IS NULL").fetchall()
    if not rows: return
    payload = b"".join(os.fsencode(r["archive_rel"]) + b"\0" for r in rows)
    with timed(f"rsync {len(rows)} archive file(s)"):
        run(["rsync", "-a", "--from0", "--files-from=-", "--relative", "./", f"{REMOTE}:{REMOTE_ARCHIVE}"],
            input_data=payload, cwd=ARCHIVE)
    expected = [{"path": r["archive_rel"], "size": r["size"], "sha256": r["sha256"]} for r in rows]
    with timed(f"verify {len(rows)} remote archive file(s)"):
        remote_verify(REMOTE_ARCHIVE, expected)
    for r in rows:
        con.execute("UPDATE messages SET state='BACKUP_VERIFIED',backup_verified_at=?,last_error=NULL WHERE id=?", (now(), r["id"]))
    con.commit()
    for r in rows:
        project_best_effort(r["message_id"], add=("gmail-trash-pending",), remove=("archive-pending", "archive-error"))

def require_ok(result, operation):
    typ, data = result
    if typ != "OK": raise RuntimeError(f"IMAP {operation} failed")
    return data

class ImapSessionFailure(RuntimeError):
    """An IMAP connection failure that makes the remaining batch unsafe."""

class NoRedirect(urllib.request.HTTPRedirectHandler):
    """Keep the OAuth bearer token on the fixed Gmail API origin."""

    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None

def fetch_identity(data, far_uid):
    metadata, literal = b"", None
    for item in data or ():
        if isinstance(item, tuple) and len(item) == 2: metadata += item[0]; literal = item[1]
        elif isinstance(item, bytes): metadata += item
    uid = re.search(rb"(?:^|[ (])UID (\d+)(?:[ )]|$)", metadata)
    gm = re.search(rb"X-GM-MSGID (\d+)", metadata)
    if not uid or int(uid.group(1)) != far_uid or not gm or literal is None:
        raise RuntimeError("FETCH did not return exact UID identity")
    mid = email.parser.BytesParser().parsebytes(literal, headersonly=True).get("Message-ID")
    return gm.group(1).decode(), mid

def index_staging_paths(rows):
    """Index candidate near UIDs with one pass over the staging Maildir."""
    candidates = {}
    for row in rows:
        near_uid = row["near_uid"]
        if near_uid in candidates:
            raise RuntimeError(f"duplicate candidate near UID {near_uid} "
                               f"(rows {candidates[near_uid]} and {row['id']})")
        candidates[near_uid] = row["id"]
    paths = {}
    for box in ("cur", "new"):
        for path in (ROOT / "[Gmail]" / "All Mail" / box).iterdir():
            match = re.search(r",U=(\d+)(?:,|:|$)", path.name)
            if not match:
                continue
            near_uid = int(match.group(1))
            if near_uid not in candidates:
                continue
            if near_uid in paths:
                raise RuntimeError(f"multiple staging files for near UID {near_uid}")
            paths[near_uid] = path
    return paths

def search_uids(data):
    """Parse a successful IMAP SEARCH response into numeric UIDs."""
    uids = set()
    for chunk in data or ():
        if chunk is None:
            continue
        if not isinstance(chunk, bytes):
            raise RuntimeError("malformed IMAP SEARCH response")
        for token in chunk.split():
            if not token.isdigit():
                raise RuntimeError("non-numeric UID in IMAP SEARCH response")
            uids.add(int(token))
    return uids

def gmail_api_message_absent(gm_id, token, opener=None):
    """Return whether Gmail's API reports this exact X-GM-MSGID not found."""
    if not isinstance(gm_id, str) or not re.fullmatch(r"[1-9][0-9]*", gm_id):
        raise RuntimeError("invalid X-GM-MSGID for Gmail API lookup")
    value = int(gm_id, 10)
    if value > 2**64 - 1:
        raise RuntimeError("X-GM-MSGID exceeds unsigned 64-bit range")
    api_id = format(value, "x")
    url = f"https://gmail.googleapis.com/gmail/v1/users/me/messages/{api_id}?format=minimal"
    request = urllib.request.Request(url, headers={
        "Accept": "application/json",
        "Authorization": f"Bearer {token}",
    })
    opener = opener or urllib.request.build_opener(NoRedirect)
    try:
        response = opener.open(request, timeout=15)
    except urllib.error.HTTPError as exc:
        body = exc.read(65537)
        if exc.code != 404 or len(body) > 65536:
            raise RuntimeError(f"Gmail API lookup failed with HTTP {exc.code}") from exc
        try:
            payload = json.loads(body)
            code = payload["error"]["code"]
        except (KeyError, TypeError, ValueError) as parse_error:
            raise RuntimeError("malformed Gmail API 404 response") from parse_error
        if code != 404:
            raise RuntimeError("contradictory Gmail API 404 response")
        return True
    except (urllib.error.URLError, TimeoutError, OSError) as exc:
        raise RuntimeError("Gmail API lookup failed") from exc
    with response:
        body = response.read(65537)
        if response.getcode() != 200 or len(body) > 65536:
            raise RuntimeError("unexpected Gmail API response")
    try:
        payload = json.loads(body)
    except (TypeError, ValueError) as exc:
        raise RuntimeError("malformed Gmail API response") from exc
    if not isinstance(payload, dict) or payload.get("id") != api_id:
        raise RuntimeError("Gmail API identity mismatch")
    return False

def checked_regular(path, label):
    st = path.lstat()
    if not stat.S_ISREG(st.st_mode): raise RuntimeError(f"{label} is not a regular non-symlink file")
    return st

def imap_move(con, limit):
    query = "SELECT * FROM messages WHERE (state='BACKUP_VERIFIED' OR (state='ERROR' AND backup_verified_at IS NOT NULL)) ORDER BY id LIMIT ?"
    rows = con.execute(query, (limit,)).fetchall()
    if not rows:
        return
    with timed(f"index staging paths for {len(rows)} message(s)"):
        staging_paths = index_staging_paths(rows)

    with timed("OAuth access token"):
        token = run(["oama", "access", "gojun077@gmail.com"], capture=True).stdout.decode().strip()
    auth = f"user=gojun077@gmail.com\1auth=Bearer {token}\1\1".encode()
    imap_timings = {}
    imap_counts = {}
    api_timing = 0.0
    api_counts = {"present": 0, "not_found": 0, "error": 0}
    session_errors = (imaplib.IMAP4.abort, imaplib.IMAP4.readonly, EOFError, OSError)

    def imap_call(label, function, *args, **kwargs):
        started = time.monotonic()
        try:
            try:
                return function(*args, **kwargs)
            except session_errors as exc:
                raise ImapSessionFailure(f"IMAP session failed during {label}: {exc}") from exc
        finally:
            imap_timings[label] = imap_timings.get(label, 0.0) + time.monotonic() - started
            imap_counts[label] = imap_counts.get(label, 0) + 1

    def mark_error(row, exc):
        con.execute("UPDATE messages SET state='ERROR',attempts=attempts+1,last_error=? WHERE id=?",
                    (str(exc), row["id"]))
        con.commit()
        project_best_effort(row["message_id"], add=("archive-error",))

    def api_absent(gm_id):
        nonlocal api_timing
        started = time.monotonic()
        try:
            absent = gmail_api_message_absent(gm_id, token)
        except Exception:
            api_counts["error"] += 1
            raise
        finally:
            api_timing += time.monotonic() - started
        api_counts["not_found" if absent else "present"] += 1
        return absent

    with timed("IMAP TLS connection"):
        im = imaplib.IMAP4_SSL("imap.gmail.com")
    try:
        imap_call("authenticate", im.authenticate, "XOAUTH2", lambda _: auth)
        capability_data = require_ok(imap_call("capability", im.capability), "CAPABILITY")
        capabilities = set(b" ".join(capability_data or ()).decode("ascii").upper().split())
        if "MOVE" not in capabilities: raise RuntimeError("server lacks MOVE capability")
        require_ok(imap_call("select", im.select, '"[Gmail]/All Mail"', readonly=False),
                   "SELECT All Mail")
        uidvalidity = int(im.response("UIDVALIDITY")[1][0])
        if any(row["source_uidvalidity"] != uidvalidity for row in rows):
            raise RuntimeError("UIDVALIDITY changed")

        failures = 0
        moved = []
        for r in rows:
            try:
                typ, data = imap_call("fetch", im.uid, "FETCH", str(r["far_uid"]),
                                      "(UID X-GM-MSGID BODY.PEEK[HEADER.FIELDS (MESSAGE-ID)])")
                if typ != "OK": raise RuntimeError("IMAP FETCH failed")
                fetch_error = None
                try:
                    gm_id, fetched_mid = fetch_identity(data, r["far_uid"])
                except RuntimeError as exc:
                    fetch_error = exc
                else:
                    normalize = lambda value: value.strip().lower() if value else None
                    if normalize(fetched_mid) != normalize(r["message_id"]): raise RuntimeError("Message-ID mismatch")
                    if r["x_gm_msgid"] and gm_id != r["x_gm_msgid"]:
                        raise RuntimeError("X-GM-MSGID mismatch")
                    if not r["x_gm_msgid"]:
                        con.execute("UPDATE messages SET x_gm_msgid=? WHERE id=?", (gm_id, r["id"]))
                        con.commit()
                    require_ok(imap_call("move", im.uid, "MOVE", str(r["far_uid"]),
                                         '"[Gmail]/Trash"'), "MOVE")

                source_uids = search_uids(require_ok(
                    imap_call("search", im.uid, "SEARCH", None, f"UID {r['far_uid']}"),
                    "SEARCH All Mail"))
                if source_uids - {r["far_uid"]}:
                    raise RuntimeError("unexpected UID in All Mail search response")
                if source_uids:
                    if fetch_error:
                        raise fetch_error
                    raise RuntimeError("MOVE source absence not proven")
                if fetch_error:
                    if not r["x_gm_msgid"]:
                        raise fetch_error
                    gm_id = r["x_gm_msgid"]
                moved.append((r, gm_id))
            except ImapSessionFailure:
                raise
            except Exception as exc:
                failures += 1
                mark_error(r, exc)

        if moved:
            require_ok(imap_call("select", im.select, '"[Gmail]/Trash"', readonly=True),
                       "SELECT Trash")
        for r, gm_id in moved:
            try:
                trash_uids = search_uids(require_ok(
                    imap_call("search", im.uid, "SEARCH", None, "X-GM-MSGID", gm_id),
                    "SEARCH Trash"))
                if not trash_uids and not api_absent(gm_id):
                    raise RuntimeError("MOVE destination presence not proven")
                arc = ARCHIVE / r["archive_rel"]
                aa = checked_regular(arc, "archive")
                if aa.st_size != r["size"] or sha(arc) != r["sha256"]: raise RuntimeError("archive safety check failed")
                src = staging_paths.get(r["near_uid"])
                if src is not None:
                    ss = checked_regular(src, "staging file")
                    if ss.st_size != r["size"] or ((ss.st_dev, ss.st_ino) != (aa.st_dev, aa.st_ino) and sha(src) != r["sha256"]): raise RuntimeError("staging file safety check failed")
                    src.unlink(); fsync_dir(src.parent)
                con.execute("UPDATE messages SET state='FINALIZED',x_gm_msgid=?,last_error=NULL WHERE id=?", (gm_id, r["id"])); con.commit()
                project_best_effort(r["message_id"], remove=("archive-pending", "gmail-trash-pending", "archive-error"))
            except ImapSessionFailure:
                raise
            except Exception as exc:
                failures += 1
                mark_error(r, exc)
        run(["notmuch", "new"])
        if failures:
            raise RuntimeError(f"{failures} Gmail MOVE operation(s) failed; inspect gmail-archive status")
    finally:
        try:
            with contextlib.suppress(ImapSessionFailure):
                imap_call("logout", im.logout)
        finally:
            for label in ("authenticate", "capability", "select", "fetch", "move", "search", "logout"):
                if label in imap_timings:
                    print(f"gmail-archive: timing IMAP {label}: {imap_timings[label]:.3f}s "
                          f"({imap_counts[label]} call(s))",
                          file=sys.stderr)
            if sum(api_counts.values()):
                print(f"gmail-archive: timing Gmail API lookup: {api_timing:.3f}s "
                      f"({api_counts['present']} present, {api_counts['not_found']} not found, "
                      f"{api_counts['error']} error)", file=sys.stderr)

def cmd_sync(args):
    with locked(), connect() as con:
        with timed("mbsync All Mail"):
            run(["mbsync", "gmail:[Gmail]/All Mail"])
        with timed("notmuch new before archive"):
            run(["notmuch", "new"])
        with timed("refresh deletion intents"):
            deletion_paths = refresh_deletions(con)
            reconcile_purge_requests(con, deletion_paths)
        with timed(f"archive up to {args.limit} message(s)"):
            archive_batch(con, args.limit, deletion_paths)
        try:
            with timed("archive backup transaction"):
                backup_rows(con)
        except Exception as exc:
            rows = con.execute("SELECT id,message_id FROM messages WHERE state IN ('ARCHIVED','ERROR') AND backup_verified_at IS NULL").fetchall()
            con.executemany("UPDATE messages SET state='ERROR',attempts=attempts+1,last_error=? WHERE id=?",
                            ((str(exc), row["id"]) for row in rows)); con.commit()
            for row in rows: project_best_effort(row["message_id"], add=("archive-error",))
            raise
        if args.move_gmail:
            with timed(f"Gmail MOVE up to {args.move_limit} message(s)"):
                imap_move(con, args.move_limit)

def purge_path(row):
    rel = Path(row["archive_rel"])
    if rel.is_absolute() or ".." in rel.parts:
        raise RuntimeError("unsafe archive path in purge journal")
    path = ARCHIVE / rel
    if os.path.commonpath((str(ARCHIVE.resolve()), str(path.resolve()))) != str(ARCHIVE.resolve()):
        raise RuntimeError("purge path escapes archive root")
    return path

def verify_local_purge_file(row):
    path = purge_path(row)
    st = checked_regular(path, "purge candidate")
    if st.st_nlink != 1 or st.st_size != row["size"] or sha(path) != row["sha256"]:
        raise RuntimeError("local purge candidate failed identity check")
    return path

def select_purge_rows(con, limit, max_bytes):
    rows = con.execute(
        "SELECT m.*,p.state purge_state,p.requested_at purge_requested_at,"
        "p.eligible_at purge_eligible_at FROM purge_requests p "
        "JOIN messages m ON m.id=p.message_id "
        "WHERE (p.state='WAITING' AND p.eligible_at<=?) OR "
        "p.state IN ('REMOTE_DELETE_STARTED','REMOTE_DELETED','LOCAL_DELETE_STARTED') "
        "ORDER BY CASE p.state WHEN 'WAITING' THEN 1 ELSE 0 END,m.id", (now(),)).fetchall()
    selected, total = [], 0
    for row in rows:
        if len(selected) >= limit or total + row["size"] > max_bytes:
            continue
        selected.append(row)
        total += row["size"]
    return selected, total

def cancel_purge(con, row):
    con.execute("UPDATE purge_requests SET state='CANCELED',last_error=NULL "
                "WHERE message_id=? AND state='WAITING'", (row["id"],))
    con.commit()
    project_best_effort(row["message_id"], remove=("purge-pending", "purge-error"))

def purge_one(con, row, token):
    state = row["purge_state"]
    path = purge_path(row)
    if state == "WAITING":
        if path not in current_deletion_paths():
            cancel_purge(con, row)
            return
        if not row["x_gm_msgid"] or not gmail_api_message_absent(row["x_gm_msgid"], token):
            raise RuntimeError("message is still present in Gmail")
        verify_local_purge_file(row)
        remote_verify(REMOTE_ARCHIVE, [{"path": row["archive_rel"], "size": row["size"],
                                        "sha256": row["sha256"]}])
        if path not in current_deletion_paths():
            cancel_purge(con, row)
            return
        changed = con.execute(
            "UPDATE purge_requests SET state='REMOTE_DELETE_STARTED',last_error=NULL "
            "WHERE message_id=? AND state='WAITING'", (row["id"],))
        if changed.rowcount != 1:
            raise RuntimeError("purge request changed before irreversible transition")
        con.commit()
        state = "REMOTE_DELETE_STARTED"
    if state == "REMOTE_DELETE_STARTED":
        verify_local_purge_file(row)
        remote_delete(REMOTE_ARCHIVE, [{"path": row["archive_rel"], "size": row["size"],
                                        "sha256": row["sha256"], "allow_missing": True}])
        con.execute("UPDATE purge_requests SET state='REMOTE_DELETED',remote_deleted_at=?,"
                    "last_error=NULL WHERE message_id=?", (now(), row["id"]))
        con.commit()
        state = "REMOTE_DELETED"
    if state == "REMOTE_DELETED":
        verify_local_purge_file(row)
        con.execute("UPDATE purge_requests SET state='LOCAL_DELETE_STARTED',last_error=NULL "
                    "WHERE message_id=?", (row["id"],))
        con.commit()
        state = "LOCAL_DELETE_STARTED"
    if state == "LOCAL_DELETE_STARTED":
        if path.exists():
            verify_local_purge_file(row)
            path.unlink()
            fsync_dir(path.parent)
        if path.exists() or path.is_symlink():
            raise RuntimeError("local purge candidate remains after unlink")
        stamp = now()
        con.execute("UPDATE purge_requests SET state='PURGED',local_deleted_at=?,last_error=NULL "
                    "WHERE message_id=?", (stamp, row["id"]))
        con.execute("UPDATE messages SET state='PURGED',last_error=NULL WHERE id=?", (row["id"],))
        con.commit()
        project_best_effort(row["message_id"], remove=("purge-pending", "purge-error"))

def cmd_purge(args):
    if args.limit > PURGE_MAX_MESSAGES:
        raise RuntimeError(f"purge limit cannot exceed {PURGE_MAX_MESSAGES} messages")
    if args.max_bytes > PURGE_MAX_BYTES:
        raise RuntimeError(f"purge byte limit cannot exceed {PURGE_MAX_BYTES} bytes")
    with locked(), connect() as con:
        run(["notmuch", "new"])
        deletion_paths = refresh_deletions(con)
        reconcile_purge_requests(con, deletion_paths)
        rows, total = select_purge_rows(con, args.limit, args.max_bytes)
        for row in rows:
            print(f"{row['id']}: {row['purge_state']} {row['size']} bytes "
                  f"eligible {row['purge_eligible_at']} {row['archive_rel']}")
        print(f"purge candidates: {len(rows)} message(s), {total} byte(s)")
        if not args.apply or not rows:
            if rows and not args.apply:
                print("dry run: rerun with --apply to approve this bounded batch")
            return
        waiting = any(row["purge_state"] == "WAITING" for row in rows)
        token = None
        if waiting:
            token = run(["oama", "access", "gojun077@gmail.com"], capture=True).stdout.decode().strip()
        failures = 0
        for row in rows:
            try:
                purge_one(con, row, token)
            except Exception as exc:
                failures += 1
                con.execute("UPDATE purge_requests SET attempts=attempts+1,last_error=? "
                            "WHERE message_id=?", (str(exc), row["id"]))
                con.commit()
                project_best_effort(row["message_id"], add=("purge-error",))
                print(f"gmail-archive: purge row {row['id']} failed: {exc}", file=sys.stderr)
        run(["notmuch", "new"])
        if failures:
            raise RuntimeError(f"{failures} purge operation(s) failed; inspect gmail-archive status")

def cmd_status(_args):
    with connect(readonly=True) as con:
        for row in con.execute("SELECT state,count(*) n FROM messages GROUP BY state ORDER BY state"):
            print(f"{row['state']}: {row['n']}")
        print("deletion-intents:", con.execute("SELECT count(*) FROM deletion_intents").fetchone()[0])
        exists = con.execute(
            "SELECT 1 FROM sqlite_master WHERE type='table' AND name='purge_requests'").fetchone()
        if exists:
            for row in con.execute(
                    "SELECT state,count(*) n FROM purge_requests GROUP BY state ORDER BY state"):
                print(f"purge-{row['state'].lower()}:", row["n"])
        else:
            print("purge-schema: pending writable command")

def cmd_backup_notmuch(_args):
    with locked():
        if not DB.is_file():
            raise RuntimeError(f"journal missing: run gmail-archive init first ({DB})")
        directory = ROOT / "state-backups"; directory.mkdir(parents=True, exist_ok=True)
        stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        paths = [directory / f"notmuch-{stamp}.dump.gz", directory / f"notmuch-{stamp}.sqlite3"]
        temps = [Path(str(path) + f".tmp-{os.getpid()}") for path in paths]
        try:
            with temps[0].open("wb") as out:
                # notmuch 0.38 accepts --include once per metadata kind; its
                # default already includes config, properties, and tags.
                subprocess.run(["notmuch", "dump", "--gzip"], stdout=out, check=True)
                out.flush(); os.fsync(out.fileno())
            with connect(readonly=True) as source, sqlite3.connect(temps[1]) as target:
                source.backup(target); target.commit()
            with temps[1].open("rb") as snapshot: os.fsync(snapshot.fileno())
            for temp, path in zip(temps, paths): os.replace(temp, path)
            fsync_dir(directory)
            probe = [{"path": path.name, "size": path.stat().st_size, "sha256": sha(path)} for path in paths]
            hostdir = socket.gethostname().split(".")[0]
            run(["rsync", "-a", "--mkpath", *(str(path) for path in paths),
                 f"{REMOTE}:{REMOTE_NOTMUCH}{hostdir}/"])
            remote_verify(REMOTE_NOTMUCH + hostdir, probe)
            complete = []
            for dump in sorted(directory.glob("notmuch-????????T??????Z.dump.gz")):
                database = directory / dump.name.replace(".dump.gz", ".sqlite3")
                if database.is_file(): complete.append((dump, database))
            for pair in complete[:-7]:
                for path in pair: path.unlink()
            fsync_dir(directory)
        finally:
            for temp in temps:
                try: temp.unlink()
                except FileNotFoundError: pass

def positive(value):
    number = int(value)
    if number <= 0: raise argparse.ArgumentTypeError("must be a positive integer")
    return number

def main():
    p = argparse.ArgumentParser(description="Durable Gmail archive (safe mode unless --move-gmail is explicit)")
    sub = p.add_subparsers(dest="command", required=True)
    sub.add_parser("init", help="create local schema/directories and configure notmuch").set_defaults(func=cmd_init)
    s = sub.add_parser("sync", help="sync, archive and verify backup; never MOVE by default")
    s.add_argument("--limit", type=positive, default=100, help="maximum new messages (default: 100)")
    s.add_argument("--move-gmail", action="store_true", help="explicitly MOVE verified exact UIDs to Gmail Trash")
    s.add_argument("--move-limit", type=positive, default=100, help="maximum Gmail moves (default: 100)")
    s.set_defaults(func=cmd_sync)
    purge = sub.add_parser("purge", help="list eligible permanent purges; requires --apply to delete")
    purge.add_argument("--limit", type=positive, default=PURGE_MAX_MESSAGES,
                       help=f"maximum messages (default: {PURGE_MAX_MESSAGES})")
    purge.add_argument("--max-bytes", type=positive, default=PURGE_MAX_BYTES,
                       help=f"maximum total bytes (default: {PURGE_MAX_BYTES})")
    purge.add_argument("--apply", action="store_true",
                       help="approve deletion of the exact bounded batch shown")
    purge.set_defaults(func=cmd_purge)
    sub.add_parser("status", help="show local journal counts (read-only)").set_defaults(func=cmd_status)
    sub.add_parser("backup-notmuch", help="dump metadata, upload, verify, retain latest seven").set_defaults(func=cmd_backup_notmuch)
    args = p.parse_args()
    try: args.func(args)
    except (OSError, sqlite3.Error, subprocess.CalledProcessError, RuntimeError) as exc:
        print(f"gmail-archive: {exc}", file=sys.stderr); return 1
    return 0

if __name__ == "__main__": raise SystemExit(main())
