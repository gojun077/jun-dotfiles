#!/usr/bin/env bash
#
# Created on: Nov 24 2022
# Last Updated: Mar 15 2026
#
# Master pre-commit hook that executes child scripts in hooks/pre-commit.d/
# Git executes this script from the root of the repository.

# If you are using this in a real repo, this path is usually
# .git/hooks/pre-commit.d
HOOKS_DIR=".git/hooks/pre-commit.d"

if [ ! -d "$HOOKS_DIR" ]; then
    # If the directory doesn't exist, we just skip (or you could exit 1 if it's mandatory)
    exit 0
fi

EXIT_CODE=0

# Loop over executable files in the directory
# We use find to avoid issues with globbing if the directory is empty
for hook in "$HOOKS_DIR"/*; do
    # Ensure it's a file and it's executable
    if [ -f "$hook" ] && [ -x "$hook" ]; then
        printf "Running hook: %s\n" "$(basename "$hook")"

        # Execute the hook. We DO NOT 'cd' into the directory.
        # This ensures the child scripts run with the repo root as the CWD.
        "$hook"
        RESULT=$?

        if [ $RESULT -ne 0 ]; then
            printf "❌ %s failed (exit code %s)\n" "$(basename "$hook")" "$RESULT"
            EXIT_CODE=1
        fi
    fi
done

if [ $EXIT_CODE -ne 0 ]; then
    printf "\n🚨 Commit aborted due to failing pre-commit hooks.\n"
    exit $EXIT_CODE
fi

exit 0
