# enable color support of ls and also add handy aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias ssha='ssh -o "IdentitiesOnly yes"'
alias scpa='scp -o "IdentitiesOnly yes"'
#alias ls='ls -G'
alias vi='vim'
alias ㅊㅇ='cd'
alias 니='ls'
alias screen="/usr/local/bin/screen"
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
alias enox="/opt/homebrew/bin/emacsclient -nw"

# SC override is to quiet the warning about non-constant path to source
# shellcheck disable=SC1090
source ~/.bash_aliases_secure
